tuple = (10, 20, 30, 50, 60) 
print(tuple)

# single tuple
tup = (30,) 
print(tup)

# Accesing elements
print(tuple[0])
print(tuple[-1])

# Slicing a tuple 
print(tuple[0:4])

# Nested Tuple
t = (1, 3, 5), (6,7,8)
print(t[1] [0])
print(t[0] [0])

# Concatenation of tuples
tuple1 = (1, 2, 3)
tuple2 = (4, 5, 6)
tuple = tuple1 + tuple2
print(tuple)
